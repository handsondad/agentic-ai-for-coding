# ─────────────────────────────────────────────
# AI Agent 应用环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ⚠️ 警告：.env 文件包含敏感信息，不要提交到版本库！
# ─────────────────────────────────────────────

# ── LLM 配置 ──────────────────────────────────
# OpenAI API Key（必填）
OPENAI_API_KEY=sk-your-api-key-here

# 自定义 API 端点（可选，默认使用 OpenAI 官方）
# OPENAI_BASE_URL=https://api.openai.com/v1

# 默认模型（可选）
# OPENAI_MODEL=gpt-4o

# ── 应用配置 ───────────────────────────────────
# 服务端口（默认 8000）
PORT=8000

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 最大并发会话数（默认 10）
MAX_CONCURRENT_SESSIONS=10

# ── 数据库配置（如果使用）────────────────────────
# DATABASE_URL=******localhost:5432/aiagent

# ── Redis 配置（如果使用）────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── GitHub 集成（Automation 使用）───────────────────
# GitHub Personal Access Token（用于 Automation 读取 Issues）
# GITHUB_TOKEN=ghp_your-token-here

# 仓库标识符（owner/repo 格式）
# GITHUB_REPOSITORY=your-org/your-repo

# Automation 工作空间根目录
# AUTOMATION_WORKSPACE_ROOT=/tmp/automation_workspaces

# ── 安全配置 ───────────────────────────────────
# JWT 密钥（生产环境必须使用强随机字符串）
# SECRET_KEY=your-secret-key-change-in-production

# API 访问令牌（可选，用于保护 API 端点）
# API_TOKEN=your-api-token-here
